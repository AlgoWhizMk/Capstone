<p data-start="692" data-end="709"><code data-start="692" data-end="709">seatingCapacity</code></p>
</li>
</ul>
<h3 data-section-id="1xwgtew" data-start="711" data-end="728">📐 Dimensions</h3>
<ul data-start="729" data-end="767">
<li data-section-id="1oupfks" data-start="729" data-end="767">
<p data-start="731" data-end="767"><code data-start="731" data-end="742">length_cm</code>, <code data-start="744" data-end="754">width_cm</code>, <code data-start="756" data-end="767">height_cm</code></p>
</li>
</ul>
<h3 data-section-id="q8lkvh" data-start="769" data-end="791">🏢 Context / Usage</h3>
<ul data-start="792" data-end="824">
<li data-section-id="1vxii4a" data-start="792" data-end="805">
<p data-start="794" data-end="805"><code data-start="794" data-end="805">usageArea</code></p>
</li>
