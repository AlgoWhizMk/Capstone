<p data-start="510" data-end="525"><code data-start="510" data-end="525">furnitureType</code></p>
</li>
<li data-section-id="1b5uiph" data-start="526" data-end="535">
<p data-start="528" data-end="535"><code data-start="528" data-end="535">color</code></p>
</li>
<li data-section-id="8h4b0u" data-start="536" data-end="553">
<p data-start="538" data-end="553"><code data-start="538" data-end="553">surfaceFinish</code></p>
</li>
<li data-section-id="110u5ag" data-start="554" data-end="569">
<p data-start="556" data-end="569"><code data-start="556" data-end="569">topMaterial</code></p>
</li>
<li data-section-id="17iztr2" data-start="570" data-end="587">
<p data-start="572" data-end="587"><code data-start="572" data-end="587">frameMaterial</code></p>
</li>
<li data-section-id="kqjt89" data-start="588" data-end="609">
<p data-start="590" data-end="609"><code data-start="590" data-end="609">enclosureMaterial</code></p>
</li>
</ul>
<h3 data-section-id="19l29af" data-start="611" data-end="636">🏗️ Structure &amp; Build</h3>
<ul data-start="637" data-end="709">
<li data-section-id="1kq0iub" data-start="637" data-end="655">
<p data-start="639" data-end="655"><code data-start="639" data-end="655">frameThickness</code></p>
</li>
